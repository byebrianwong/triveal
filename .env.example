# --- App (optional: falls back to the bundled seed bank when absent) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Private question bank as base64 JSON, for deploys where the gitignored
# lib/questions/private-bank.json file isn't present (e.g. Vercel).
#   base64 -i lib/questions/private-bank.json | pbcopy
CLUEDOWN_PRIVATE_BANK=

# --- Offline pipeline only (never needed by the live app) ---
ANTHROPIC_API_KEY=
